AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------------------------------------------------------------------------
# Hikvision PULL via ISUP Bridge
# ---------------------------------------------------------------------------
# Laravel consume un Bridge ISUP externo; estos son los únicos valores que
# Laravel necesita. NO se guardan por dispositivo en base de datos.
HIK_BRIDGE_URL=http://159.223.166.80:16233
HIK_BRIDGE_TOKEN=dRmhyGrMxBGW7KNiXY_b6Iq7xrlLahFDGAh5YvzVEL1KWo88kpqcZR-hVulctVug
HIK_BRIDGE_TIMEOUT=15
HIK_EVENTS_MAX_RESULTS=30
HIK_EVENTS_LOOKBACK_MINUTES=10

# Cadencia del scheduler (minutos). N>1 => "*/N * * * *"; N<=1 => "* * * * *"
HIK_SYNC_SCHEDULE_MINUTES=5
HIK_PULL_SCHEDULE_MINUTES=1

# Las variables HIK_* siguientes son consumidas por el BRIDGE, NO por Laravel.
# Se documentan aquí solo como referencia del lado del servidor ISUP/EHome.
# HIK_PUBLIC_IP=159.223.166.80
# HIK_CMS_LISTEN_IP=0.0.0.0
# HIK_CMS_LISTEN_PORT=7660
# HIK_DAS_IP=159.223.166.80
# HIK_DAS_PORT=7660
# HIK_ISUP_KEY=hik12345

VITE_APP_NAME="${APP_NAME}"
